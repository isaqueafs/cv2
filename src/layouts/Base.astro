---
import '../styles/global.css'
import '@tabler/icons-webfont/dist/tabler-icons.css'

interface Props {
    title?: string
    description?: string
    lang?: string
}

const {
    title = 'Isaque Santos | dev web',
    description = 'Dev web full-stack com 5+ anos de experiência em PHP, JavaScript, Laravel e Go.',
    lang = 'pt-BR',
} = Astro.props

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
        <link rel="icon" href={`${base}/favicon.ico`} />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:locale" content={lang === 'pt-BR' ? 'pt_BR' : 'en_US'} />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap"
            rel="stylesheet"
        />

        <!-- Spotlight nos cards -->
        <script is:inline>
            document.addEventListener('mousemove', function (e) {
                document.querySelectorAll('.card-glow').forEach(function (card) {
                    var rect = card.getBoundingClientRect()
                    card.style.setProperty('--mouse-x', (e.clientX - rect.left) + 'px')
                    card.style.setProperty('--mouse-y', (e.clientY - rect.top) + 'px')
                })
            })
        </script>

        <!-- Anti-flash tema -->
        <script is:inline>
            ;(function () {
                var match = document.cookie.match(/(?:^|;\s*)theme=([^;]+)/)
                var theme = match ? match[1] : 'dark'
                document.documentElement.setAttribute('data-theme', theme)
            })()
        </script>
    </head>
    <body class="min-h-screen bg-canvas text-text antialiased">
        <slot />
    </body>
</html>
