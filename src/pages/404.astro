---
import Base from '../layouts/Base.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Base title="404 — Isaque Santos" lang="pt-BR">
    <main class="h-screen flex items-center justify-center px-4">
        <div class="w-full max-w-md">

            <div class="bg-surface border border-accent/30 rounded p-8">

                <p class="text-xs text-muted uppercase tracking-widest mb-6"> > 404 not found</p>

                <h1 class="font-display text-8xl text-accent leading-none tracking-wide mb-1">
                    PERDIDO?
                </h1>

                <p class="text-xs text-muted font-mono mb-6 leading-relaxed">
                    Essa rota não existe. Mas quem sabe você estava
                    procurando pelo dev que a construiu.
                </p>

                <div class="border-t border-border pt-5 space-y-2">
                    <a href={`${base}/`}
                       class="flex items-center gap-3 text-sm text-muted hover:text-text transition-colors duration-150 group">
                        <i class="ti ti-home text-accent/70 text-base w-4 group-hover:text-accent transition-colors duration-150"></i>
                        <span>isaque santos · dev web</span>
                    </a>
                    <a href={`${base}/#contato`}
                       class="flex items-center gap-3 text-sm text-muted hover:text-text transition-colors duration-150 group">
                        <i class="ti ti-mail text-accent/70 text-base w-4 group-hover:text-accent transition-colors duration-150"></i>
                        <span>isaqueafsantos@gmail.com</span>
                    </a>
                    <a href={`${base}/en/`}
                       class="flex items-center gap-3 text-sm text-muted hover:text-text transition-colors duration-150 group">
                        <i class="ti ti-world text-accent/70 text-base w-4 group-hover:text-accent transition-colors duration-150"></i>
                        <span>switch to english version</span>
                    </a>
                </div>

            </div>

        </div>
    </main>
</Base>
