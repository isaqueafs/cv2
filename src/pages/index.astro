                                Alura <i class="ti ti-external-link text-xs"></i>
                            </a>
                            <p class="text-xs text-muted mt-0.5">Certificado completo — dev web</p>
                        </div>
                    </div>
                </div>

                <!-- Idiomas -->
                <div class="card-glow bg-surface border border-border rounded p-5 transition-colors duration-200 hover:border-accent/30 hover:bg-surface-raised">
                    <p class="text-xs text-muted uppercase tracking-widest mb-4">
                        <span class="text-accent"> > idiomas</span>
                    </p>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-text">Português</span>
                            <span class="text-xs text-muted font-mono">Nativo</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-text">Inglês</span>
                            <span class="text-xs text-muted font-mono">Profissional</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-text">Espanhol</span>
                            <span class="text-xs text-muted font-mono">Básico</span>
                        </div>
                    </div>
                </div>

                <!-- Projetos -->
                <div class="card-glow bg-surface border border-border rounded p-5 transition-colors duration-200 hover:border-accent/30 hover:bg-surface-raised sm:col-span-2">
                    <p class="text-xs text-muted uppercase tracking-widest mb-3">
                        <span class="text-accent"> > projetos</span>
                    </p>
                    <p class="text-sm text-muted leading-relaxed">
                        Seção em construção. Confira meu trabalho no{" "}
                        <a href="https://linkedin.com/in/isaqueafs"
                            target="_blank" rel="noopener noreferrer"
                            class="text-accent hover:text-accent/80 transition-colors duration-150">
                            LinkedIn
                        </a>.
                    </p>
                </div>

            </div>

            <footer class="pt-4 border-t border-border flex items-center justify-between gap-6 flex-wrap">
                <p class="text-xs text-muted font-mono">© {year} Isaque Santos</p>
                <div class="flex items-center gap-4">
                    <a href="mailto:isaqueafsantos@gmail.com"
                       class="flex items-center gap-1.5 text-xs text-muted hover:text-text transition-colors duration-150">
                        <i class="ti ti-mail text-accent/70"></i>
                        <span>isaqueafsantos@gmail.com</span>
                    </a>
                    <a href="https://linkedin.com/in/isaqueafs"
                       target="_blank" rel="noopener noreferrer"
                       class="flex items-center gap-1.5 text-xs text-muted hover:text-text transition-colors duration-150">
                        <i class="ti ti-brand-linkedin text-accent/70"></i>
                        <span>isaqueafs</span>
                    </a>
                    <a href="tel:+5517982052201"
                       class="flex items-center gap-1.5 text-xs text-muted hover:text-text transition-colors duration-150">
                        <i class="ti ti-phone text-accent/70"></i>
                        <span>(17) 98205-2201</span>
                    </a>
                </div>
            </footer>
        </div>
    </main>
</Base>

<script>
    const btn = document.getElementById("theme-toggle")!;

    function getTheme() {
        return document.documentElement.getAttribute("data-theme") || "dark";
    }

    function updateLabel() {
        btn.innerHTML = getTheme() === "dark"
            ? '<i class="ti ti-sun"></i>'
            : '<i class="ti ti-moon"></i>'
    }

    btn.addEventListener("click", () => {
        const next = getTheme() === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        document.documentElement.classList.add("theme-ready");
        document.cookie = `theme=${next};path=/;max-age=31536000;SameSite=Lax`;
        updateLabel();
    });

    updateLabel();
</script>
