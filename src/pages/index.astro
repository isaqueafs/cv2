---
import Base from "../layouts/Base.astro";

const year = new Date().getFullYear()
---

<Base title="Isaque Santos | dev web" lang="pt-BR">
    <main class="min-h-screen bg-canvas text-text">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 space-y-4">
            <!-- Intro -->
            <div class="mb-8">
                <div class="flex items-start justify-between gap-4 mb-3">
                    <h1 class="font-display text-5xl text-accent tracking-wide leading-none">
                        Isaque Santos
                    </h1>
                    <div class="flex items-center gap-3 pt-1 shrink-0">
                        <div class="text-xs font-mono text-muted flex items-center gap-1">
                            <a href="/" class="text-text">pt-br</a>
                            <span>/</span>
                            <a href="/en/" class="hover:text-text transition-colors duration-150">en-us</a>
                        </div>
                        <button
                            id="theme-toggle"
                            class="text-muted hover:text-text text-xs font-mono border border-border rounded px-2 py-0.5 hover:border-accent/40 transition-colors duration-150">
                        </button>
                    </div>
                </div>
                <p class="text-sm text-text/70 font-mono">
                    Desenvolvedor Web Full-Stack · São José do Rio Preto, SP ·
                    PHP, JavaScript · 5+ anos
                </p>
            </div>

            <!-- Grid de cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                <!-- Sobre -->
                <div class="card-glow bg-surface border border-border rounded p-5 transition-colors duration-200 hover:border-accent/30 hover:bg-surface-raised sm:col-span-2">
                    <p class="text-xs text-muted uppercase tracking-widest mb-3">
                        <span class="text-accent"> > sobre</span>
                    </p>
                    <p class="text-sm text-text leading-relaxed">
                        Desenvolvedor apaixonado por construir produtos web que
                        funcionam de verdade. Atuo com PHP e JavaScript no dia a
                        dia, sempre buscando código limpo e soluções que façam
                        sentido para o negócio.
                    </p>
                </div>

                <!-- Experiência -->
                <div class="card-glow bg-surface border border-border rounded p-5 transition-colors duration-200 hover:border-accent/30 hover:bg-surface-raised sm:col-span-2">
                    <p class="text-xs text-muted uppercase tracking-widest mb-4">
                        <span class="text-accent"> > experiência</span>
                    </p>
                    <div class="border-l border-border pl-4">
                        <div class="flex items-baseline justify-between gap-4 mb-1.5">
                            <span class="text-sm font-medium text-text">MoveEdu</span>
                            <span class="text-xs text-muted font-mono shrink-0">Out 2020 – presente</span>
                        </div>
                        <div class="space-y-1">
                            <p class="text-xs text-muted">Analista de Desenvolvimento</p>
                            <p class="text-xs text-muted">Desenvolvedor Full Stack Pleno</p>
                            <p class="text-xs text-muted">Desenvolvedor Full Stack Junior</p>
                        </div>
                    </div>
                </div>

                <!-- Skills -->
                <div class="card-glow bg-surface border border-border rounded p-5 transition-colors duration-200 hover:border-accent/30 hover:bg-surface-raised sm:col-span-2">
                    <p class="text-xs text-muted uppercase tracking-widest mb-5">
                        <span class="text-accent"> > skills</span>
                    </p>
                    <div class="grid grid-cols-2 gap-5">
                        <div>
                            <p class="text-xs text-muted font-mono mb-2">backend</p>
                            <div class="flex flex-wrap gap-1.5">
                                {['PHP', 'Laravel', 'Livewire', 'Go'].map(s => (
                                    <span class="text-xs font-mono text-text bg-canvas border border-border rounded px-2 py-0.5">{s}</span>
                                ))}
                            </div>
                        </div>
                        <div>
                            <p class="text-xs text-muted font-mono mb-2">frontend</p>
                            <div class="flex flex-wrap gap-1.5">
                                {['JS/TS', 'Tailwind', 'Bootstrap'].map(s => (
                                    <span class="text-xs font-mono text-text bg-canvas border border-border rounded px-2 py-0.5">{s}</span>
                                ))}
                            </div>
                        </div>
                        <div>
                            <p class="text-xs text-muted font-mono mb-2">banco de dados</p>
                            <div class="flex flex-wrap gap-1.5">
                                {['MySQL', 'PostgreSQL'].map(s => (
                                    <span class="text-xs font-mono text-text bg-canvas border border-border rounded px-2 py-0.5">{s}</span>
                                ))}
                            </div>
                        </div>
                        <div>
                            <p class="text-xs text-muted font-mono mb-2">devops</p>
                            <div class="flex flex-wrap gap-1.5">
                                {['Docker'].map(s => (
                                    <span class="text-xs font-mono text-text bg-canvas border border-border rounded px-2 py-0.5">{s}</span>
                                ))}
                            </div>
                        </div>
                        <div>
                            <p class="text-xs text-muted font-mono mb-2">ferramentas</p>
                            <div class="flex flex-wrap gap-1.5">
                                {['Git', 'NPM', 'Composer', 'Vite'].map(s => (
                                    <span class="text-xs font-mono text-text bg-canvas border border-border rounded px-2 py-0.5">{s}</span>
                                ))}
