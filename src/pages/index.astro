                        </div>
                    </div>
                </div>

                <!-- Formação -->
                <div class="card-glow bg-surface border border-border rounded p-5 transition-colors duration-200 hover:border-accent/30 hover:bg-surface-raised">
                    <p class="text-xs text-muted uppercase tracking-widest mb-4">
                        <span class="text-accent"> > formação & certificações</span>
                    </p>
                    <div class="space-y-3">
                        <div class="border-l border-border pl-4">
                            <span class="text-sm font-medium text-text">Senac Brasil</span>
                            <p class="text-xs text-muted mt-0.5">Análise e Desenvolvimento de Sistemas</p>
                        </div>
                        <div class="border-l border-border pl-4">
                            <a href="https://cursos.alura.com.br/user/isaque-santos0/fullCertificate/2d3211521741cb72f0c2c6a8b673279d"
                               target="_blank" rel="noopener noreferrer"
